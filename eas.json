{
  "cli": {
    "version": ">= 16.32.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk"
      }
    },
    "testflight": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "production",
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "production",
      "ios": {
        "buildConfiguration": "Release"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "brian.gboko@southlandglobal.africa",
        "language": "fr-FR"
      }
    },
    "testflight": {
      "ios": {
        "appleId": "brian.gboko@southlandglobal.africa",
        "language": "fr-FR"
      }
    }
  }
}
